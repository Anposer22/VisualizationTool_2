{
    "include": [
        "./src/**/*"
    ],
    "compilerOptions": {
        "strict": false,
        "noImplicitAny": false,
        "esModuleInterop": true,
        "lib": [
            "dom",
            "es2015",
            "es2015.iterable",
            "es2015.collection"
        ],
        "jsx": "react-jsx",
        "downlevelIteration": true,
        "skipLibCheck": true
    }
}
